# Production environment template. Copy to `.env` on the production host (or
# feed these as real environment variables via your deployment platform) and
# fill in every value below — Settings' production validator
# (app/config/settings.py) will refuse to start if any of them are missing
# or still a development default.

APP_NAME=MissionOS Backend
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# The real origin(s) your frontend is served from. No localhost/127.0.0.1 —
# the production validator rejects those. Comma-separated if there's more
# than one (e.g. a staging + a production frontend origin).
CORS_ORIGINS=https://app.your-domain.example

# Point this at your production Postgres instance. If you're using the
# provided docker-compose.prod.yml, POSTGRES_PASSWORD below must match.
DATABASE_URL=postgresql+psycopg://missionos:CHANGE_ME@postgres:5432/missionos

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# Must be at least 32 characters and must not be the repo's dev default.
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Required — AI analysis fails on every request without it.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=30
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Where the RAG pipeline persists its ChromaDB index and uploaded dataset
# files, relative to the backend/ working directory.
VECTOR_STORE_DIR=storage/vectorstore
RAG_CHUNK_ROW_SIZE=25
RAG_TOP_K=6
UPLOAD_DIR=storage/uploads
MAX_UPLOAD_SIZE_BYTES=26214400

# --- Used by docker-compose.prod.yml for the postgres service itself ---
POSTGRES_DB=missionos
POSTGRES_USER=missionos
POSTGRES_PASSWORD=
