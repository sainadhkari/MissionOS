APP_NAME=MissionOS Backend
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=postgresql+psycopg://missionos:missionos@localhost:5432/missionos
JWT_SECRET_KEY=change-me-to-a-random-secret-in-every-environment
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
OPENAI_API_KEY=sk-your-openai-api-key-here
# 30s fits this default model (gpt-4o-mini, non-reasoning). Switching
# OPENAI_MODEL to a reasoning-tier model (o1/o3/o4/gpt-5 families) needs a
# much higher value -- measured live, the Risk agent alone can take ~70s at
# reasoning effort "low" before writing any visible output, since
# max_output_tokens is a budget shared between invisible reasoning tokens
# and the visible response. 200 is a safe starting point for those models.
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=30
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
VECTOR_STORE_DIR=storage/vectorstore
RAG_CHUNK_ROW_SIZE=25
RAG_TOP_K=6
UPLOAD_DIR=storage/uploads
MAX_UPLOAD_SIZE_BYTES=26214400
