APP_NAME=MissionOS Backend
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=postgresql+psycopg://missionos:missionos@localhost:5432/missionos
JWT_SECRET_KEY=change-me-to-a-random-secret-in-every-environment
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=30
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
VECTOR_STORE_DIR=storage/vectorstore
RAG_CHUNK_ROW_SIZE=25
RAG_TOP_K=6
